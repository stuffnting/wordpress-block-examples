{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "snt/meta-richtext",
  "version": "0.1.0",
  "title": "SNT Meta RichText",
  "category": "snt-block-category",
  "icon": "lightbulb",
  "description": "Testing using a RichTExt component with post metadata",
  "attributes": {
    "sntMeta": {
      "type": "string",
      "_comment": "The meta field key must not be private, i.e. must not start with `_`",
      "default": "_snt_meta_richtext_field"
    }
  },
  "supports": {
    "html": false,
    "multiple": false
  },
  "usesContext": ["postId", "postType"],
  "textdomain": "snt",
  "editorScript": "file:./meta-richtext.js",
  "style": "file:./style-meta-richtext.css",
  "render": "file:./render.php"
}
